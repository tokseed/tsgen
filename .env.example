# LLM Provider Configuration
# Выберите один из провайдеров: GigaChat или OpenRouter

# === GigaChat API (Сбер) ===
# 1. Зарегистрируйте приложение в СберБизнес: https://developers.sber.ru/
# 2. Получите Client ID и Client Secret
# 3. Формат: ClientID:ClientSecret (через двоеточие, без пробелов)
# Пример: GIGACHAT_CREDENTIALS=abc123def456:xyz789uvw012
GIGACHAT_CREDENTIALS=

# === OpenRouter API ===
# Получите ключ на https://openrouter.ai/
OPENROUTER_API_KEY=

# Приоритетный провайдер: "gigachat" | "openrouter" | "auto"
# auto = автоматически выбирает доступный провайдер
LLM_PROVIDER=auto

# === LangFuse - Трекинг и метрики (опционально) ===
# Получите ключи на https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# === App Configuration ===
APP_URL=http://localhost:8000
