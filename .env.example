# LLM Provider Configuration
# Выберите один из провайдеров: GigaChat или OpenRouter

# === GigaChat API (Сбер) ===
# Получите ключи на https://developers.sber.ru/
# Формат: client_id:client_secret (через двоеточие)
GIGACHAT_CREDENTIALS=

# === OpenRouter API ===
# Получите ключ на https://openrouter.ai/
OPENROUTER_API_KEY=

# Приоритетный провайдер: "gigachat" | "openrouter" | "auto"
LLM_PROVIDER=auto
